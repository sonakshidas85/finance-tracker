<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- No network, analytics, or third-party SDK permissions - local-only app. WorkManager and
         Glance widgets do not require any extra runtime permissions on API 26+. -->

    <!-- android:allowBackup is intentionally false: this is a local-only financial app, and
         Android's auto-backup (cloud or device-transfer) would copy the encrypted-at-rest
         DataStore file off-device into a backup store we don't control. Tradeoff: users don't get
         automatic restore when switching phones - see README "Security" section. -->
    <application
        android:name=".BudgetApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BudgetTracker">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.BudgetTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Small floating popup launched only by this app's own WEEKLY widget (via
             actionStartActivity from a PendingIntent it creates itself), for the "Custom"
             quick-add entry point - never a launcher activity, and exported="false" since nothing
             outside this app ever needs to start it. -->
        <activity
            android:name=".QuickAddSpendActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.BudgetTracker.Dialog" />

        <!-- Weekly widget -->
        <receiver
            android:name=".widget.WeeklyBudgetWidgetReceiver"
            android:exported="false"
            android:label="@string/weekly_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/weekly_widget_info" />
        </receiver>

        <!-- Monthly widget -->
        <receiver
            android:name=".widget.MonthlyBudgetWidgetReceiver"
            android:exported="false"
            android:label="@string/monthly_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/monthly_widget_info" />
        </receiver>

    </application>

</manifest>
