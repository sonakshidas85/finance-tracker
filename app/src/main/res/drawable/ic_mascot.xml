<?xml version="1.0" encoding="utf-8"?>
<!-- Standalone "Bean" illustration for empty states and error states (MascotMessage.kt), ported
     1:1 from the brand guidelines' primary mascot SVG (viewBox 0 0 200 214) with no scaling
     transform - every coordinate below is copied verbatim from the guideline doc. Includes the
     soft ground shadow, which the app-icon crop omits. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="107dp"
    android:viewportWidth="200"
    android:viewportHeight="214">
    <!-- Ground shadow -->
    <path
        android:fillColor="#33C04A"
        android:fillAlpha="0.14"
        android:pathData="M 50,200 a 50,8 0 1,0 100,0 a 50,8 0 1,0 -100,0 Z" />
    <!-- Antenna stem -->
    <path
        android:strokeColor="#123322"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:pathData="M 100,52
            C 100,40 86,40 90,26
            C 97,31 110,32 104,48" />
    <!-- Antenna tip -->
    <path
        android:fillColor="#33C04A"
        android:pathData="M 85,24 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0 Z" />
    <!-- Body -->
    <path
        android:fillColor="#33C04A"
        android:pathData="M 66,72
            C 66,52 134,52 134,74
            C 138,120 138,152 132,178
            C 112,196 88,196 68,178
            C 62,152 62,120 66,72
            Z" />
    <!-- Cheek dots (coin, 60% opacity) -->
    <path
        android:fillColor="#FFC83A"
        android:fillAlpha="0.6"
        android:pathData="M 53,150 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z" />
    <path
        android:fillColor="#FFC83A"
        android:fillAlpha="0.6"
        android:pathData="M 133,150 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z" />
    <!-- Eyes (white, ink stroke) -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#123322"
        android:strokeWidth="3"
        android:pathData="M 66,108 a 20,20 0 1,0 40,0 a 20,20 0 1,0 -40,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#123322"
        android:strokeWidth="3"
        android:pathData="M 94,108 a 20,20 0 1,0 40,0 a 20,20 0 1,0 -40,0 Z" />
    <!-- Pupils -->
    <path
        android:fillColor="#123322"
        android:pathData="M 78,110 a 10,10 0 1,0 20,0 a 10,10 0 1,0 -20,0 Z" />
    <path
        android:fillColor="#123322"
        android:pathData="M 102,110 a 10,10 0 1,0 20,0 a 10,10 0 1,0 -20,0 Z" />
    <!-- Eye highlights -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 80.8,106 a 3.2,3.2 0 1,0 6.4,0 a 3.2,3.2 0 1,0 -6.4,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 104.8,106 a 3.2,3.2 0 1,0 6.4,0 a 3.2,3.2 0 1,0 -6.4,0 Z" />
    <!-- Mouth -->
    <path
        android:fillColor="#123322"
        android:pathData="M 94,146 a 6,8 0 1,0 12,0 a 6,8 0 1,0 -12,0 Z" />
</vector>
