<?xml version="1.0" encoding="utf-8"?>
<!--
    Sizes chosen to straddle both SizeMode.Responsive buckets declared in WeeklyBudgetWidget.kt
    (SMALL = 100dp x 60dp, MEDIUM = 220dp x 120dp):
      - minWidth/minHeight: the smallest size a freshly-placed widget can be (~2x1 cells).
      - minResizeWidth/minResizeHeight: same as minWidth/minHeight - the smallest the user can
        drag-resize down to, still landing in the SMALL responsive bucket.
      - targetCellWidth/targetCellHeight (API 31+): tells launchers that default-place this widget
        at 2x1 cells, matching the SMALL layout.
      - resizeMode="horizontal|vertical": lets the user resize in both axes so they can grow the
        widget up into the MEDIUM (~4x2) bucket.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="100dp"
    android:minHeight="60dp"
    android:minResizeWidth="100dp"
    android:minResizeHeight="60dp"
    android:maxResizeWidth="220dp"
    android:maxResizeHeight="120dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewLayout="@android:layout/simple_list_item_1"
    android:description="@string/weekly_widget_description"
    android:updatePeriodMillis="0" />
