<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. The actual color scheme is driven by Compose's
         BudgetTrackerTheme (ui/theme/Theme.kt); this XML theme mainly sets the window
         background/status bar to sane defaults before Compose content is drawn, and is
         referenced by the Activity + widget host process. -->
    <style name="Theme.BudgetTracker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/background_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Used only by QuickAddSpendActivity, the small popup the WEEKLY widget launches for
         typing an exact quick-add amount (RemoteViews/Glance can't host a real text field, so
         this Activity - floating over the home screen rather than full-screen - is the other
         half of that platform workaround; see widget/WidgetContent.kt and
         QuickAddSpendActivity.kt). windowIsFloating + a transparent background let the
         Activity's own Compose content draw a small centered rounded card instead of taking over
         the whole screen like a normal app launch. -->
    <style name="Theme.BudgetTracker.Dialog" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
